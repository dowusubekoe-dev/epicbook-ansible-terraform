# ---------------------------
# Node.js dependencies
# ---------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production builds (if any)
dist/
build/

# ---------------------------
# Environment variables / secrets
# ---------------------------
.env
.env.*
config/*.local.js

# ---------------------------
# Ansible generated files
# ---------------------------
inventory.ini
inventory/
*.retry

# Terraform output artifacts (downloaded during pipeline)
tfoutputs.json

# ---------------------------
# SSH keys (CRITICAL - never commit)
# ---------------------------
*.pem
*.key
id_rsa
id_rsa.pub

# Azure DevOps secure file downloads
secure-files/

# ---------------------------
# Logs
# ---------------------------
logs/
*.log

# ---------------------------
# OS / IDE
# ---------------------------
.DS_Store
.vscode/
.idea/

# ---------------------------
# Ansible temporary artifacts
# ---------------------------
*.swp
*.bak